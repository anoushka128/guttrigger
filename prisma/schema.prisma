generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile         UserProfile?
  meals           Meal[]
  symptoms        Symptom[]
  checkIns        CheckIn[]
  reminders       Reminder[]
  analysisResults AnalysisResult[]

  @@map("users")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mainGoal            String   @default("identify_triggers")
  trackedSymptoms     String[]
  knownAllergies      String[]
  suspectedFoods      String[]
  dietaryRestrictions String[]
  remindersEnabled    Boolean  @default(false)
  mealsPerDay         Int      @default(3)
  onboardingComplete  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

model Meal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date     DateTime
  mealType String   // breakfast | lunch | dinner | snack
  title    String
  location String   @default("home")
  notes    String?
  photoUrl String?
  logLevel Int      @default(1)

  foods    MealFood[]
  symptoms Symptom[]  @relation("MealSymptoms")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meals")
}

model MealFood {
  id     String @id @default(cuid())
  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  name        String
  portionSize String?
  portionDesc String?
  category    String?

  ingredients MealIngredient[]

  createdAt DateTime @default(now())

  @@map("meal_foods")
}

model MealIngredient {
  id         String   @id @default(cuid())
  mealFoodId String
  mealFood   MealFood @relation(fields: [mealFoodId], references: [id], onDelete: Cascade)

  name     String
  quantity String?
  category String?

  createdAt DateTime @default(now())

  @@map("meal_ingredients")
}

model Symptom {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  timeStarted DateTime
  severity    Int
  categories  String[]
  duration    String?
  onset       String?
  notes       String?
  isSevere    Boolean  @default(false)

  linkedMeals Meal[] @relation("MealSymptoms")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("symptoms")
}

model CheckIn {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  timestamp    DateTime @default(now())
  feelingScore Int?
  energyLevel  Int?
  stressLevel  Int?
  sleepHours   Float?
  sleepQuality Int?
  hadBM        Boolean?
  bmType       String?
  cravings     String?
  notes        String?
  symptoms     String[]

  createdAt DateTime @default(now())

  @@map("check_ins")
}

model Reminder {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  time    String
  enabled Boolean @default(true)
  label   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reminders")
}

model AnalysisResult {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  foodName        String
  foodCategory    String?
  exposureCount   Int     @default(0)
  symptomCount    Int     @default(0)
  avgSeverity     Float   @default(0)
  consistency     Float   @default(0)
  confidenceScore Float   @default(0)
  suspicionLevel  String  @default("insufficient_data")
  dominantOnset   String?
  linkedSymptoms  String[]

  lastCalculated DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, foodName])
  @@map("analysis_results")
}
